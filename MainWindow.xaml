<Window x:Class="Singularity.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Singularity"
        Width="450" Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded">

    <Grid Background="#FF0A0A0A">
        <Button Content="X"
                Width="30" Height="30"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,10,0"
                Click="CloseButton_Click"
                Background="Transparent"
                Foreground="#FF777777"
                FontWeight="Bold"
                BorderBrush="{x:Null}" Cursor="Hand"/>

        <StackPanel VerticalAlignment="Top"
                    Margin="0,80,0,0"
                    HorizontalAlignment="Center">
            <TextBlock Text="SINGULARITY"
                       FontSize="26" Foreground="White"
                       FontWeight="SemiBold"
                       TextAlignment="Center" />
            <TextBlock Text="CENTER"
                       FontSize="14" Foreground="#AAFFFFFF"
                       TextAlignment="Center" />
        </StackPanel>

        <Button x:Name="LaunchButton"
                Width="220" Height="220"
                Click="LaunchButton_Click"
                BorderBrush="#55FFFFFF"
                BorderThickness="2"
                Cursor="Hand"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Ellipse Stroke="{TemplateBinding BorderBrush}"
                                 StrokeThickness="{TemplateBinding BorderThickness}">
                            <Ellipse.Fill>
                                <RadialGradientBrush GradientOrigin="0.5,0.5"
                                                     Center="0.5,0.5"
                                                     RadiusX="0.6" RadiusY="0.6">
                                    <GradientStop Color="#141414" Offset="0"/>
                                    <GradientStop Color="#0a0a0a" Offset="1"/>
                                </RadialGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                    </Grid>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Button Content="FOLDER"
                Width="80" Height="30"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,30"
                Click="FolderButton_Click"
                Background="Transparent"
                Foreground="#FFD4A35F"
                FontWeight="Bold"
                BorderBrush="{x:Null}" Cursor="Hand" FontSize="16"/>

        <TextBlock x:Name="DownloadLog"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   TextAlignment="Center"
                   Margin="0,80,0,50"
                   Foreground="White"
                   FontSize="14"
                   TextWrapping="Wrap"
                   Width="400"
                   Height="100"/>
    </Grid>
</Window>