<Window x:Class="Singularity.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Singularity"
        Width="450" Height="600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        Loaded="Window_Loaded">
    <Border Background="#FF0A0A0A"
            CornerRadius="20"
            SnapsToDevicePixels="True"
            Padding="0">
        <Grid>

            <StackPanel VerticalAlignment="Top"
                        HorizontalAlignment="Center"
                        Margin="0,80,0,0">
                <TextBlock Text="SINGULARITY"
                           FontSize="26"
                           Foreground="White"
                           FontWeight="SemiBold"
                           TextAlignment="Center"/>
                <TextBlock Text="CENTER"
                           FontSize="14"
                           Foreground="#AAFFFFFF"
                           TextAlignment="Center"/>
            </StackPanel>

            <Button x:Name="CloseButton"
                    Width="36" Height="36"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,10,0"
                    Click="CloseButton_Click"
                    Background="Transparent"
                    BorderBrush="{x:Null}"
                    Cursor="Hand">
                <Path Data="M0,0 L10,10 M0,10 L10,0"
                    Stroke="#55FFFFFF"
                    StrokeThickness="2"
                    Width="10" Height="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

            </Button>

            <Button x:Name="LaunchButton"
        Width="220" Height="220"
        Click="LaunchButton_Click"
        BorderBrush="#55FFFFFF"
        BorderThickness="2"
        Cursor="Hand"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Background="Transparent">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="GlowEllipse" Opacity="0.4" StrokeThickness="0">
                                <Ellipse.Fill>
                                    <RadialGradientBrush GradientOrigin="0.5,0.5"
                                             Center="0.5,0.5"
                                             RadiusX="0.8" RadiusY="0.8">
                                        <GradientStop Color="#55FFFFFF" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                                <Ellipse.Effect>
                                    <BlurEffect Radius="25"/>
                                </Ellipse.Effect>
                            </Ellipse>

                            <Ellipse x:Name="MainEllipse"
                         Stroke="{TemplateBinding BorderBrush}"
                         StrokeThickness="{TemplateBinding BorderThickness}">
                                <Ellipse.Fill>
                                    <RadialGradientBrush GradientOrigin="0.5,0.5"
                                             Center="0.5,0.5"
                                             RadiusX="0.6" RadiusY="0.6">
                                        <GradientStop Color="#141414" Offset="0"/>
                                        <GradientStop Color="#0a0a0a" Offset="1"/>
                                    </RadialGradientBrush>
                                </Ellipse.Fill>
                            </Ellipse>

                            <Ellipse x:Name="HoverGlow"
                         Opacity="0"
                         Fill="#252525">
                                <Ellipse.Effect>
                                    <BlurEffect Radius="15"/>
                                </Ellipse.Effect>
                            </Ellipse>
                            
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverGlow"
                                 Storyboard.TargetProperty="Opacity"
                                 To="0" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="GlowEllipse"
                                 Storyboard.TargetProperty="Opacity"
                                 To="0.4" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="MainEllipse"
                                 Storyboard.TargetProperty="StrokeThickness"
                                 To="2" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </VisualState>

                                    <VisualState x:Name="MouseOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverGlow"
                                 Storyboard.TargetProperty="Opacity"
                                 To="0.5" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="GlowEllipse"
                                 Storyboard.TargetProperty="Opacity"
                                 To="0.8" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="MainEllipse"
                                 Storyboard.TargetProperty="StrokeThickness"
                                 To="3" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </VisualState>

                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverGlow"
                                 Storyboard.TargetProperty="Opacity"
                                 To="0.7" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="MainEllipse"
                                 Storyboard.TargetProperty="StrokeThickness"
                                 To="4" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </VisualState>

                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                        </Grid>
                    </ControlTemplate>
                </Button.Template>
            </Button>


            <TextBlock x:Name="DownloadLog"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       TextAlignment="Center"
                       Margin="0,444,0,0"
                       Foreground="White"
                       FontSize="14"
                       TextWrapping="Wrap"
                       Width="400"
                       Height="100"/>

            <Button Content="FOLDER"
                    Width="80" Height="30"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,30"
                    Click="FolderButton_Click"
                    Background="Transparent"
                    Foreground="#FFD4A35F"
                    FontWeight="Bold"
                    BorderBrush="{x:Null}" Cursor="Hand" FontSize="16"/>

        </Grid>
    </Border>
</Window>